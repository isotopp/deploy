def site_factory(config: dict) -> Deployable:
    type_ = config.get("type")
    project_ = config.get("project")
    debug(f"{type_} {project_}")
    if type_ is None:
        raise ValueError(f"must specify a valid --type ")
    if project_ is None:
        raise ValueError(f"must specify a project name")

    classname = VALID_PROJECT_TYPES.get(type_)
    if classname is None:
        raise ValueError(f"invalid type '{type_}'")

    module = importlib.import_module('__main__')
    cls = getattr(module, classname)
    site = cls(config)

    return site


def main():
    try:
        get_opts()

        # show is special, we have no instance
        if args.operation == "show":
            do_show(vars(args))
            sys.exit(0)

        config = vars(args)
        if args.operation == "create":
            # create is special, we need to make an initial instance
            site = site_factory(config)
        else:
            # make instance from saved project and simulate args
            site = do_load_project(config)
            config = site.project

        try:
            operation = getattr(site, args.operation)
        except AttributeError:
            print(f"Invalid operation: {site} has no operation {args.operation}")
            sys.exit(1)
        operation(config)
    except Exception as e:
        if args.debug > 0:
            traceback.print_exc()
        else:
            print(f"Error: {e}")


if __name__ == "__main__":
    main()
