class Deployable:
    """
    Impure abstract superclass for all the various site types we have.
    Each subclass must implement the following methods:

    - ``create()``: creates the site (and the projectfile)
    - ``delete()``: deletes the site (and the projectfile)
    - ``show()``: display the projectfile
    - ``start()``: stop the service
    - ``stop()``: stop the service
    - ``update()``: update the github, if one exists
    - ``restart()``: restart the service after updating
    - ``logs()``: show the services logs

    """

    def __init__(self, config):
        self.args = config
        self.project = {
            'project': config.get('project')
        }

    def __repr__(self):
        return f'Deployable({self.project})'

    def _not_implemented(self):
        stack = inspect.stack()
        caller_method = stack[1].function  # our caler
        current_class = self.__class__.__name__
        raise NotImplementedError(f'class {current_class} does not implement {caller_method}()')

    # The set of methods that every subclass of Deployable has to implement
    def create(self, config):
        self._not_implemented()

    def delete(self, config):
        self._not_implemented()

    def start(self, config):
        """ Start httpd systemd service.
            Needs to be overwritten by DiscordBot
        """
        debug("")
        do_systemd_start("httpd")

    def stop(self, config):
        """ Stop httpd systemd service.
            Needs to be overwritten by DiscordBot.
        """
        debug("")
        do_systemd_stop("httpd")

    def restart(self, config):
        """ Restart httpd systemd service.
            Needs to be overwritten by DiscordBot.
        """
        debug("")
        httpd_restart()

    def update(self, config):
        self._not_implemented()

    def logs(self, config):
        """ Show httpd logs.
            Needs to be overwritten by DiscordBot.
        """
        debug(f"")
        hostname = config['hostname']
        debug(f'exec tail -F {LOG_DIR}/httpd/{{access,error}}-{hostname}.log')
        os.execvp('bash', ['bash', '-c', f'tail -F {LOG_DIR}/httpd/{{access,error}}-{hostname}.log'])

    # argument validation
    def validate_args(self):
        """ validate the argus for the class (common mandatory and optional args)
            and put then into self.project.
        """
        self.mandatory('type')

    def mandatory(self, optname):
        """ make sure a mandatory arg is given, and copy it into self.project """
        debug(f"{optname=}")
        if self.args.get(optname, None) is None:
            raise TypeError(f'missing mandatory option {optname}')

        self.project[optname] = self.args[optname]

    def optional(self, optname, default_optvalue):
        """ check if an optional arg is given and copy it into self.project """
        debug(f"{optname=} {default_optvalue=}")
        v = self.args.get(optname)
        if v is None:
            v = default_optvalue
        self.project[optname] = v


class RedirectSite(Deployable):
    """ create a redirect site '''hostname''' which redirects to '''to_hostname'''

        '''deploy create wwwexamplecom --type redirect_site --hostname www.example.com --to-hostname example.com'''

    """

    def __init__(self, config):
        debug("")
        super().__init__(config)
        self.project['type'] = 'redirect_site'
        self.validate_args()

    def validate_args(self):
        debug("")
        super().validate_args()
        self.mandatory('hostname')
        self.mandatory('to_hostname')

    def _create_apache_config(self):
        """ Create an apache config in /etc/httpd/conf.sites.d/{config.hostname}.conf. """
        debug("")

        config_filename = f"/etc/httpd/conf.sites.d/{self.project['hostname']}.conf"
        config_content = "# autogenerated by /usr/local/bin/deploy, overwritten on next run.\n" \
                         f"Use RedirectVHost {self.project['hostname']} {self.project['to_hostname']}\n" \
                         "# vim: syntax=apache ts=4 sw=4 sts=4 sr noet\n"
        to_file(config_content, config_filename)

    def create(self, config):
        """ create a RedirectSite:

             - write out the projectfile
             - write out the apache config
             - restart the apache to pick up the config change
         """
        debug(f"{self.project=}")
        p = self.project

        create_projectfile(p)  # self.project now has all necessary details
        self._create_apache_config()
        httpd_restart()
        print(f"project {p['project']} ({p['type']}) created")

    def delete(self, config):
        """ delete a RedirectSite:

             - delete the apache config file
             - delete the project file
             - perform the restart (so that we do not collect the old domain)
         """
        debug(f"{self.project=}")
        p = self.project

        delete_apache_config(p['hostname'])
        delete_project_file(p['project'])  # first delete the project file
        httpd_restart()
        print(f"project {p['project']} ({p['type']}) deleted")

    def update(self, config):
        """ RedirectSites have nothing to do. """
        return


