def do_create_systemd_service(project: str, target: str, username: str):
    """ Create a systemd service in /etc/systemd/system/{project}.service. """
    debug(f"{project=} {target=} {username=}")

    config_filename = Path(f"/etc/systemd/system/{project}.service")
    config_content = f"""
[Unit]
Description={project}
After=syslog.target network.target

[Service]
Type=simple
User={username}
Group={username}
StandardOutput=journal
StandardError=journal
WorkingDirectory={target}
ExecStart={target}/venv/bin/python3 {target}/main.py
Restart=always
EnvironmentFile={target}/.env

[Install]
WantedBy=multi-user.target
"""
    to_file(config_content, config_filename)


def do_delete_systemd_service(project: str):
